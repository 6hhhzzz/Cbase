# ============================================================
# KES 企业知识助手 — 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填入实际值:  cp .env.example .env
# .env 已被 .gitignore 排除，不会提交到版本控制
#
# 各服务引用方式:
#   docker-compose.yaml → 自动读取 .env，使用 ${VAR} 语法
#   application.yml     → Spring Boot 读取环境变量，使用 ${VAR:default}
#   llm.yaml            → Python 加载时替换 ${VAR} 占位符
#   config.py           → pydantic-settings，支持 LLM__API_KEY 等嵌套覆盖
# ============================================================

# ---- LLM API 密钥 (必填) ----
# DashScope API Key (阿里云百炼)
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-key-here

# ---- PostgreSQL 数据库 ----
KES_DB_HOST=localhost
KES_DB_PORT=5432
KES_DB_NAME=kes
KES_DB_USER=kes
KES_DB_PASSWORD=kes123

# ---- Redis 缓存 ----
KES_REDIS_HOST=localhost
KES_REDIS_PORT=6379

# ---- RabbitMQ 消息队列 ----
KES_MQ_HOST=localhost
KES_MQ_PORT=5672
KES_MQ_USER=kes
KES_MQ_PASSWORD=kes123

# ---- MinIO 对象存储 ----
KES_MINIO_ENDPOINT=localhost:9000
KES_MINIO_ROOT_USER=minioadmin
KES_MINIO_ROOT_PASSWORD=minioadmin
KES_MINIO_BUCKET=kes-documents

# ---- JWT 签名密钥 ----
# 生产环境必须更换，生成方式: openssl rand -base64 32
KES_JWT_SECRET=change-me-in-production-use-256-bit-key

# ---- Python AI Service (Java 后端通信) ----
KES_JAVA_URL=http://localhost:8080

# ---- MCP 知识服务 (可选) ----
# 通过前端管理界面 → API 密钥管理 创建，然后填入此处
KES_MCP_API_KEY=
KES_MCP_SPACE_ID=

# ---- 首次启动管理员密码 (可选) ----
# 不设置则随机生成并打印到日志（仅首次启动生效）
KES_INIT_ADMIN_PASSWORD=

# ---- Docker Compose 专用变量 ----
# docker-compose.yaml 直接引用这些变量
POSTGRES_PASSWORD=kes123
RABBITMQ_DEFAULT_PASS=kes123
MINIO_ROOT_PASSWORD=minioadmin

# ---- pydantic-settings 嵌套覆盖 (可选) ----
# Python config/models.py 中的任何字段都可通过 __ 分隔符覆盖
# 例如: LLM__API_KEY=xxx  →  settings.llm.api_key
#       PGVECTOR__HOST=xxx → settings.pgvector.host
#       RABBITMQ__PASSWORD=xxx → settings.rabbitmq.password
